## Complete Examples

### Example 1: Inbound with RTP Engine (XCC)

**File**: `rtphelper/correlation_cases/inbound_xcc.yaml`

```yaml
name: inbound_xcc
description: "Inbound calls with RTP Engine cross-connect (XCC header present)"
priority: 70
enabled: true

detection:
  direction: inbound
  rules:
    - type: direction_match
      direction: inbound
      description: "Inbound call detection"

correlation:
  strategy: configurable
  force_direction: null
  annotations:
    - "production"
    - "topology:rtp_engine"
  notes: ""
  config:
    carrier_ip_source: "first_invite.src_ip"
    core_ip_source: "last_invite.dst_ip"
    xcc_ip_source: "invite_with_changed_sdp.src_ip"
    response_priority: [200]
    enable_hop_fallback: true
    enable_adjacent_packet_search: true
    block_xcc_responses: true
    rtp_engine_detection: enabled
    filter_reinvites: true
    group_multi_call_ids: true

filters:
  template_set: rtp_engine_topology
  use_default_templates: true
  custom_templates_enabled: false
```

---

### Example 2: Outbound Direct Media (No RTP Engine)

**File**: `rtphelper/correlation_cases/outbound_no_xcc.yaml`

```yaml
name: outbound_no_xcc
description: "Outbound calls with direct media path (no RTP Engine cross-connect)"
priority: 60
enabled: true

detection:
  direction: outbound
  rules:
    - type: direction_match
      direction: outbound
      description: "Outbound call detection"

correlation:
  strategy: configurable
  force_direction: null
  annotations:
    - "production"
    - "topology:direct"
  notes: ""
  config:
    carrier_ip_source: "last_invite.dst_ip"
    core_ip_source: "first_invite.src_ip"
    xcc_ip_source: null
    response_priority: [200]
    enable_hop_fallback: true
    enable_adjacent_packet_search: true
    block_xcc_responses: false
    rtp_engine_detection: disabled
    filter_reinvites: true
    group_multi_call_ids: false

filters:
  template_set: direct_topology
  use_default_templates: true
  custom_templates_enabled: false
```

---

### Example 3: Multi Call-ID (B2BUA)

**File**: `rtphelper/correlation_cases/inbound_2cid.yaml`

```yaml
name: inbound_2cid
description: "Inbound calls with 2 Call-IDs (B2BUA scenario)"
priority: 80
enabled: true

detection:
  direction: inbound
  rules:
    - type: multi_call_id
      min_call_ids: 2
      description: "At least 2 Call-IDs detected (B2BUA)"

correlation:
  strategy: configurable
  force_direction: null
  annotations:
    - "production"
    - "topology:b2bua"
    - "multi_call_id"
  notes: |
    Handles B2BUA scenarios where carrier leg and core leg have different Call-IDs.
    RTP Engine detection enabled to find 3-hop topology if present.
  config:
    carrier_ip_source: "first_invite.src_ip"
    core_ip_source: "last_invite.dst_ip"
    xcc_ip_source: "invite_with_changed_sdp.src_ip"
    response_priority: [183, 200]
    enable_hop_fallback: true
    enable_adjacent_packet_search: true
    block_xcc_responses: true
    rtp_engine_detection: enabled
    filter_reinvites: true
    group_multi_call_ids: true

filters:
  template_set: rtp_engine_topology
  use_default_templates: true
  custom_templates_enabled: false
