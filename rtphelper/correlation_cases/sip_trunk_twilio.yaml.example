name: sip_trunk_twilio
description: Twilio SIP Trunk calls with X-Twilio headers
priority: 60
enabled: true

detection:
  direction: both
  headers:
    - pattern: "x-twilio-"
      case_insensitive: true
      required: true
  method: INVITE

correlation:
  strategy: generic
  annotations:
    - "Correlator: TwilioSIPTrunkCorrelator"
    - "Carrier: Twilio"
  
  notes: |
    Twilio SIP Trunk correlation case.
    
    Detection criteria:
    - Must have X-Twilio-* header in INVITE
    - Works for both inbound and outbound calls
    
    Example headers:
    - X-Twilio-AccountSid: ACxxxxxxxxx
    - X-Twilio-CallSid: CAxxxxxxxxx
    
    Priority 60 ensures Twilio calls are matched before generic PSTN cases.
