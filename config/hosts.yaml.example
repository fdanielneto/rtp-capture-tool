rpcap:
  default_port: 2002
  auth_mode: null

settings:
  default_capture_root: /absolute/path/for/captures

# Host address configuration:
# - Static IP addresses: 10.0.10.11
# - DNS hostnames/FQDN: rtp-node-1.example.com
# DNS resolution is cached for 60s (configurable via RTPHELPER_DNS_CACHE_TTL)

environments:
  PRD:
    regions:
      EU:
        sub-region:
          eu-west-1:
            hosts:
              - id: prd-eu-west-1-rtp-1
                address: 10.0.10.11
                description: PRD EU West 1 media node 1
                interfaces: ["ens5"]
              - id: prd-eu-west-1-rtp-2
                address: rtp-node-2.example.com
                description: PRD EU West 1 media node 2 (dynamic DNS)
                interfaces: ["ens5"]
      US:
        sub-region:
          us-east-1:
            hosts:
              - id: prd-us-east-1-rtp-1
                address: 10.0.20.11
                description: PRD US East 1 media node 1
                interfaces: ["ens5"]

  QA:
    regions:
      EU:
        sub-region:
          eu-west-1:
            hosts:
              - id: qa-eu-west-1-rtp-1
                address: 10.1.10.11
                description: QA EU West 1 media node 1
                interfaces: ["ens5"]

  STG:
    regions: {}
